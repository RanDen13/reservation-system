// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
}

enum EventSpaceStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
}

enum SAPFRequestStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  RETURNED_FOR_REVISION
  REJECTED
  APPROVED
  CANCELLED
}

enum ApprovalStepStatus {
  PENDING
  ACTIVE
  APPROVED
  RETURNED
  REJECTED
  SKIPPED
}

enum ApprovalActionType {
  SUBMITTED
  RESUBMITTED
  APPROVED
  RETURNED
  REJECTED
  COMMENTED
  FINALIZED
  CANCELLED
}

enum ApproverPosition {
  ADVISER
  DEAN
  SDS
  SAS
  ADDITIONAL_SIGNATORY
  VPAA
  UNIVERSITY_PRESIDENT
}

enum ConcernThreadStatus {
  OPEN
  RESOLVED
}

enum NotificationType {
  REQUEST
  APPROVAL
  REVISION
  REJECTION
  CONFLICT
  FINAL
  COMMENT
}

enum UserRole {
  OFFICER
  APPROVER
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  role       String?
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  sapfRequests       SAPFRequest[]          @relation("OfficerRequests")
  assignedSteps      ApprovalStep[]         @relation("StepReviewer")
  approvalActions    ApprovalAction[]       @relation("ActionActor")
  approverPositions  ApproverPositionUser[]
  notifications      Notification[]
  concernMessages    ConcernMessage[]       @relation("ConcernMessageAuthor")
  officerThreads     ConcernThread[]        @relation("ConcernOfficer")
  reviewerThreads    ConcernThread[]        @relation("ConcernReviewer")
  createdVenueBlocks VenueBlock[]           @relation("VenueBlockCreator")

  @@unique([email])
  @@map("user")
}

model EventSpace {
  id           String           @id
  name         String
  location     String
  capacity     Int
  description  String
  amenities    Amenity[]
  status       EventSpaceStatus @default(ACTIVE)
  pricePerHour Float
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  image        Bytes?
  sapfRequests SAPFRequest[]
  venueBlocks  VenueBlock[]

  @@map("event_space")
}

model Amenity {
  id           String      @id
  name         String
  icon         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  eventSpace   EventSpace? @relation(fields: [eventSpaceId], references: [id])
  eventSpaceId String?

  @@map("amenity")
}

model SAPFRequest {
  id                String            @id
  requestNumber     String            @unique
  officerId         String
  officer           User              @relation("OfficerRequests", fields: [officerId], references: [id], onDelete: Cascade)
  eventSpaceId      String
  eventSpace        EventSpace        @relation(fields: [eventSpaceId], references: [id], onDelete: Cascade)
  title             String
  organization      String
  department        String
  attendeeCount     Int
  startAt           DateTime
  endAt             DateTime
  status            SAPFRequestStatus @default(DRAFT)
  currentStepOrder  Int?
  conflictWarning   Boolean           @default(false)
  rejectionReason   String?
  sapfPart1         Json
  sapfPart2         Json
  sapfPart3         String?
  sapfPart4         Json?
  verificationToken String?           @unique
  approvedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  approvalSteps   ApprovalStep[]
  approvalActions ApprovalAction[]
  notifications   Notification[]
  concernThreads  ConcernThread[]

  @@index([officerId])
  @@index([eventSpaceId])
  @@index([status])
  @@index([startAt])
  @@map("sapf_request")
}

model ApprovalStep {
  id         String             @id
  requestId  String
  request    SAPFRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepOrder  Int
  position   ApproverPosition
  label      String
  reviewerId String
  reviewer   User               @relation("StepReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  status     ApprovalStepStatus @default(PENDING)
  comment    String?
  actedAt    DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  actions       ApprovalAction[]
  concernThread ConcernThread?

  @@unique([requestId, stepOrder])
  @@index([reviewerId])
  @@index([status])
  @@map("approval_step")
}

model ApprovalAction {
  id        String             @id
  requestId String
  request   SAPFRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepId    String?
  step      ApprovalStep?      @relation(fields: [stepId], references: [id], onDelete: SetNull)
  actorId   String
  actor     User               @relation("ActionActor", fields: [actorId], references: [id], onDelete: Cascade)
  action    ApprovalActionType
  comment   String?
  createdAt DateTime           @default(now())

  @@index([requestId])
  @@index([actorId])
  @@map("approval_action")
}

model ApproverPositionUser {
  id        String           @id
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  position  ApproverPosition
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, position])
  @@index([position])
  @@map("approver_position_user")
}

model VenueBlock {
  id           String      @id
  eventSpaceId String?
  eventSpace   EventSpace? @relation(fields: [eventSpaceId], references: [id], onDelete: Cascade)
  title        String
  reason       String?
  startAt      DateTime
  endAt        DateTime
  createdById  String?
  createdBy    User?       @relation("VenueBlockCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([eventSpaceId])
  @@index([startAt])
  @@map("venue_block")
}

model Notification {
  id        String           @id
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId String?
  request   SAPFRequest?     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  type      NotificationType @default(REQUEST)
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([requestId])
  @@map("notification")
}

model ConcernThread {
  id             String              @id
  requestId      String
  request        SAPFRequest         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approvalStepId String              @unique
  approvalStep   ApprovalStep        @relation(fields: [approvalStepId], references: [id], onDelete: Cascade)
  officerId      String
  officer        User                @relation("ConcernOfficer", fields: [officerId], references: [id], onDelete: Cascade)
  reviewerId     String
  reviewer       User                @relation("ConcernReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  status         ConcernThreadStatus @default(OPEN)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  messages ConcernMessage[]

  @@index([requestId])
  @@index([officerId])
  @@index([reviewerId])
  @@map("concern_thread")
}

model ConcernMessage {
  id        String        @id
  threadId  String
  thread    ConcernThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("ConcernMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  readAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([threadId])
  @@index([authorId])
  @@map("concern_message")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
